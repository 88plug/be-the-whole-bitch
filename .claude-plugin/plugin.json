{
  "$schema": "https://json.schemastore.org/claude-code-plugin-manifest.json",
  "name": "be-the-whole-bitch",
  "displayName": "Be The Whole Bitch",
  "description": "Enforce full agent authority on reversible work: run commands yourself, never yield instructions back to the operator. Stop hook scores yield-back turns; next prompt gets a one-shot drive correction.",
  "author": {
    "name": "88plug",
    "email": "andrew@88plug.com"
  },
  "license": "FSL-1.1-ALv2",
  "homepage": "https://github.com/88plug/be-the-whole-bitch",
  "repository": "https://github.com/88plug/be-the-whole-bitch.git",
  "keywords": [
    "claude-code",
    "claude",
    "anthropic",
    "ai",
    "llm",
    "ai-agents",
    "developer-tools",
    "productivity",
    "automation",
    "cli",
    "claude-code-plugin",
    "claude-skills",
    "authority",
    "execution",
    "guardrails",
    "agent-behavior",
    "hooks",
    "instruction-following",
    "yield-detection",
    "bias-to-action"
  ],
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/session-init.sh\"",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/capture-stop.sh\"",
            "timeout": 20
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/inject-correction.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "commands": "./commands",
  "skills": "./skills"
}
